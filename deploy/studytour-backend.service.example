# Optional systemd unit — run backend on boot (stops Nginx /api 502 after reboot).
# Prereq: cd backend && npm install && npm run build
#
#   sudo cp deploy/studytour-backend.service.example /etc/systemd/system/studytour-backend.service
#   # Edit WorkingDirectory / User if your repo path differs
#   sudo systemctl daemon-reload
#   sudo systemctl enable --now studytour-backend

[Unit]
Description=StudyTour backend API (Express)
After=network.target

[Service]
Type=simple
WorkingDirectory=/root/code/StudyAbroad/backend
Environment=NODE_ENV=production
Environment=PORT=8080
ExecStart=/usr/bin/node dist/server.js
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
