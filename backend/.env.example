PORT=8080
NODE_ENV=development

# Comma-separated browser origins allowed to call the API (needed if frontend is on another host/port).
# Production behind same-domain Nginx often needs no cross-origin; leave unset in dev for permissive CORS.
# Example: CORS_ORIGIN=https://studyabroad.martxdata.com,http://localhost:5180
# CORS_ORIGIN=

# Behind reverse proxy (Nginx): trust X-Forwarded-* for rate limiting / logs
# TRUST_PROXY=1
# TRUST_PROXY_HOPS=1

# Requests / 15 min / IP (approx). Health checks are not counted.
# RATE_LIMIT_MAX_PER_IP=500

# Proposal uploads / hour / IP
# RATE_LIMIT_PROPOSALS_PER_HOUR=40

# Max proposal file bytes (default 12 MiB, capped at 20 MiB)
# PROPOSAL_MAX_BYTES=12582912

# JSON root discovery (default on); set false to hide route map in production
# EXPOSE_API_ROOT=false

TRAVEFY_BASE_URL=https://api.travefy.com
TRAVEFY_API_KEY=
TRAVEFY_TIMEOUT_MS=15000
TRAVEFY_RETRY_COUNT=2

# Optional: JSON state file (default ./data/studytour-state.json)
# STUDYTOUR_STATE_FILE=

# Research: Tavily web search (omit to use built-in mock results)
# TAVILY_API_KEY=

# Wetu / partner HTTP publish (omit both to use mock publish)
# WETU_API_BASE_URL=
# WETU_API_KEY=
# WETU_UPSERT_PATH=/v1/itineraries
# WETU_TIMEOUT_MS=20000

# Partner & traveler JSON views: set to true in production so ?token= is required
# REQUIRE_VIEW_TOKEN=false
